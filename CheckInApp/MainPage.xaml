<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CheckInApp.ViewModels"
             xmlns:converters="clr-namespace:CheckInApp.Converters"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="CheckInApp.MainPage"
             Title="Check-In Empleados"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F5F7FA">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!--  Material Design 3 Inspired Color Palette  -->
            <Color x:Key="Primary">#6750A4</Color>
            <Color x:Key="OnPrimary">#FFFFFF</Color>
            <Color x:Key="PrimaryContainer">#EADDFF</Color>
            <Color x:Key="OnPrimaryContainer">#21005D</Color>
            <Color x:Key="Secondary">#625B71</Color>
            <Color x:Key="OnSecondary">#FFFFFF</Color>
            <Color x:Key="SecondaryContainer">#E8DEF8</Color>
            <Color x:Key="OnSecondaryContainer">#1D192B</Color>
            <Color x:Key="Tertiary">#7D5260</Color>
            <Color x:Key="OnTertiary">#FFFFFF</Color>
            <Color x:Key="TertiaryContainer">#FFD8E4</Color>
            <Color x:Key="OnTertiaryContainer">#31111D</Color>
            <Color x:Key="Error">#B3261E</Color>
            <Color x:Key="OnError">#FFFFFF</Color>
            <Color x:Key="ErrorContainer">#F9DEDC</Color>
            <Color x:Key="OnErrorContainer">#410E0B</Color>
            <Color x:Key="Surface">#FEF7FF</Color>
            <Color x:Key="OnSurface">#1D1B20</Color>
            <Color x:Key="SurfaceVariant">#E7E0EC</Color>
            <Color x:Key="OnSurfaceVariant">#49454F</Color>
            <Color x:Key="Outline">#79747E</Color>
            <Color x:Key="OutlineVariant">#CAC4D0</Color>
            <Color x:Key="InverseSurface">#320F35</Color>
            <Color x:Key="InverseOnSurface">#F5EFF7</Color>
            <Color x:Key="InversePrimary">#D0BCFF</Color>
            <Color x:Key="Shadow">#000000</Color>
            <Color x:Key="SurfaceTint">#6750A4</Color>
            <Color x:Key="Scrim">#000000</Color>

            <!--  Corporate HR Color System  -->
            <Color x:Key="HRPrimary">#1A4B7A</Color>
            <Color x:Key="HRPrimaryDark">#0F2E4D</Color>
            <Color x:Key="HRPrimaryLight">#2563A8</Color>
            <Color x:Key="HRAccent">#E07B1A</Color>
            <Color x:Key="HRAccentLight">#F0920A</Color>
            <Color x:Key="PageBg">#F5F7FA</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="CardBorder">#E8ECF0</Color>
            <Color x:Key="HeaderText">#0F2E4D</Color>
            <Color x:Key="BodyText">#334155</Color>
            <Color x:Key="MutedText">#64748B</Color>
            <Color x:Key="DividerColor">#E8ECF0</Color>

            <!--  Status Color System  -->
            <Color x:Key="SuccessGreen">#15803D</Color>
            <Color x:Key="SuccessBg">#DCFCE7</Color>
            <Color x:Key="SuccessBorder">#86EFAC</Color>
            <Color x:Key="DangerRed">#B91C1C</Color>
            <Color x:Key="DangerBg">#FEE2E2</Color>
            <Color x:Key="DangerBorder">#FCA5A5</Color>
            <Color x:Key="WarnAmber">#B45309</Color>
            <Color x:Key="WarnBg">#FEF3C7</Color>
            <Color x:Key="WarnBorder">#FCD34D</Color>
            <Color x:Key="InfoBlue">#1D4ED8</Color>
            <Color x:Key="InfoBg">#DBEAFE</Color>
            <Color x:Key="InfoBorder">#93C5FD</Color>
            <Color x:Key="NeutralBg">#F1F5F9</Color>
            <Color x:Key="NeutralBorder">#CBD5E1</Color>

            <!--  Semantic Colors  -->
            <Color x:Key="Success">#4CAF50</Color>
            <Color x:Key="OnSuccess">#FFFFFF</Color>
            <Color x:Key="Warning">#FF9800</Color>
            <Color x:Key="OnWarning">#FFFFFF</Color>
            <Color x:Key="Info">#2196F3</Color>
            <Color x:Key="OnInfo">#FFFFFF</Color>

            <!--  Gradient Brushes  -->
            <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#4CAF50" />
                <GradientStop Offset="1" Color="#81C784" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FF9800" />
                <GradientStop Offset="1" Color="#FFB74D" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="InfoGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#2196F3" />
                <GradientStop Offset="1" Color="#64B5F6" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#9C27B0" />
                <GradientStop Offset="1" Color="#CE93D8" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="HeaderGradient" StartPoint="0,0" EndPoint="1,0.3">
                <GradientStop Offset="0.0" Color="#0A1F33" />
                <GradientStop Offset="0.4" Color="#0F2E4D" />
                <GradientStop Offset="0.8" Color="#1A4B7A" />
                <GradientStop Offset="1.0" Color="#1E5490" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AccentLineGradient" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Offset="0" Color="Transparent" />
                <GradientStop Offset="0.15" Color="#E07B1A" />
                <GradientStop Offset="0.5" Color="#F0920A" />
                <GradientStop Offset="0.85" Color="#E07B1A" />
                <GradientStop Offset="1" Color="Transparent" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="KpiGreenBg" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#F0FDF4" />
                <GradientStop Offset="1" Color="#FFFFFF" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="KpiBlueBg" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#EFF6FF" />
                <GradientStop Offset="1" Color="#FFFFFF" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="KpiOrangeBg" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FFF7ED" />
                <GradientStop Offset="1" Color="#FFFFFF" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="KpiPurpleBg" StartPoint="0,0" EndPoint="0,1">
                <GradientStop Offset="0" Color="#FAF5FF" />
                <GradientStop Offset="1" Color="#FFFFFF" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="ScannerLineGradient" StartPoint="0,0" EndPoint="1,0">
                <GradientStop Offset="0" Color="Transparent" />
                <GradientStop Offset="0.2" Color="#00E07B1A" />
                <GradientStop Offset="0.4" Color="#E07B1A" />
                <GradientStop Offset="0.6" Color="#F0920A" />
                <GradientStop Offset="0.8" Color="#E07B1A" />
                <GradientStop Offset="1" Color="Transparent" />
            </LinearGradientBrush>

            <!--  Shadow Definitions  -->
            <Shadow x:Key="SubtleShadow"
                    Brush="#0F2E4D"
                    Opacity="0.02"
                    Radius="3"
                    Offset="0,1" />
            <Shadow x:Key="Elevation1"
                    Brush="#0F2E4D"
                    Opacity="0.05"
                    Radius="5"
                    Offset="0,2" />
            <Shadow x:Key="Elevation2"
                    Brush="#0F2E4D"
                    Opacity="0.07"
                    Radius="10"
                    Offset="0,3" />
            <Shadow x:Key="Elevation3"
                    Brush="#0F2E4D"
                    Opacity="0.09"
                    Radius="16"
                    Offset="0,5" />
            <Shadow x:Key="CardHoverShadow"
                    Brush="#0F2E4D"
                    Opacity="0.06"
                    Radius="8"
                    Offset="0,2" />

            <!--  Base Card Style  -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
                <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
                <Setter Property="StrokeThickness" Value="0.5" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Shadow" Value="{StaticResource Elevation1}" />
            </Style>

            <!--  KPI Card Style  -->
            <Style x:Key="StatCardStyle" TargetType="Border">
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="StrokeThickness" Value="0.5" />
                <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
                <Setter Property="Shadow" Value="{StaticResource Elevation1}" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <!--  Filter Button Style  -->
            <Style x:Key="FilterButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="HeightRequest" Value="32" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="0.3" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <!--  Action Button Style  -->
            <Style x:Key="ActionBtnStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="20" />
                <Setter Property="HeightRequest" Value="32" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="0.3" />
                <Setter Property="Shadow" Value="{StaticResource Elevation1}" />
                <Setter Property="Padding" Value="0" />
            </Style>

            <!--  Section Title Style  -->
            <Style x:Key="SectionTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="10" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource MutedText}" />
                <Setter Property="CharacterSpacing" Value="1.0" />
            </Style>

            <Shadow x:Key="Shadow2"
                    Brush="#000000"
                    Radius="10"
                    Opacity="0.2"
                    Offset="0,4" />

            <!--  Converters  -->
            <converters:BoolToColorStateConverter x:Key="BgEstado"
                                                  TrueColor="{StaticResource SecondaryContainer}"
                                                  FalseColor="{StaticResource ErrorContainer}" />

            <converters:BoolToColorStateConverter x:Key="TextEstado"
                                                  TrueColor="{StaticResource OnSecondaryContainer}"
                                                  FalseColor="{StaticResource OnErrorContainer}" />

            <converters:BoolToIconConverter x:Key="EstadoIcono"
                                            TrueIcon="✓"
                                            FalseIcon="⚠" />

            <!--  Converters  -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <viewmodels:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto" RowSpacing="0">

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  HEADER — Compact Header for Mobile (1080x2336)  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Grid Grid.Row="0">
            <Border Padding="0" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0.15">
                        <GradientStop Offset="0.0" Color="#081726" />
                        <GradientStop Offset="0.35" Color="#0F2E4D" />
                        <GradientStop Offset="0.7" Color="#1A4B7A" />
                        <GradientStop Offset="1.0" Color="#1E5490" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto, 2">
                    <!--  Subtle Pattern Overlay  -->
                    <BoxView Grid.RowSpan="2"
                             Opacity="0.02"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                <GradientStop Offset="0" Color="#FFFFFF" />
                                <GradientStop Offset="0.5" Color="Transparent" />
                                <GradientStop Offset="1" Color="#FFFFFF" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                    <!--  Header Content  -->
                    <Grid Padding="14,42,14,12" ColumnDefinitions="*, Auto">
                        <!--  Left: Title  -->
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="1"
                                             VerticalOptions="Center">
                            <HorizontalStackLayout Spacing="6">
                                <Border WidthRequest="3"
                                        HeightRequest="10"
                                        BackgroundColor="#E07B1A"
                                        StrokeThickness="0"
                                        VerticalOptions="Center"
                                        StrokeShape="RoundRectangle 1.5" />
                                <Label Text="RECURSOS HUMANOS"
                                       FontSize="7.5"
                                       FontAttributes="Bold"
                                       TextColor="#7DB8E0"
                                       CharacterSpacing="2" />
                            </HorizontalStackLayout>
                            <Label Margin="0,2,0,0"
                                   Text="Control de Asistencia"
                                   FontSize="17"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"
                                   CharacterSpacing="0.2" />
                        </VerticalStackLayout>
                        <!--  Right: System Status Badge  -->
                        <Border Grid.Column="1"
                                Padding="8,6"
                                BackgroundColor="#0D2439"
                                Stroke="#1A4B7A"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 3.5"
                                VerticalOptions="Center"
                                Shadow="{StaticResource SubtleShadow}">
                            <HorizontalStackLayout Spacing="6"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center">
                                <!--  Pulsing Indicator  -->
                                <Border WidthRequest="8"
                                        HeightRequest="8"
                                        BackgroundColor="#4ADE80"
                                        Stroke="#20C55E"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        VerticalOptions="Center">
                                    <Border.Shadow>
                                        <Shadow Brush="#4ADE80"
                                                Opacity="0.4"
                                                Radius="4"
                                                Offset="0,0" />
                                    </Border.Shadow>
                                </Border>
                                <VerticalStackLayout Spacing="1">
                                    <Label Text="EN LÍNEA"
                                           FontSize="7"
                                           FontAttributes="Bold"
                                           TextColor="#4ADE80"
                                           CharacterSpacing="1" />
                                    <Label Text="Activo"
                                           FontSize="6.5"
                                           TextColor="#7DB8E0" />
                                </VerticalStackLayout>
                            </HorizontalStackLayout>
                        </Border>
                    </Grid>
                    <!--  Accent Line  -->
                    <BoxView Grid.Row="1"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill"
                             Background="{StaticResource AccentLineGradient}" />
                </Grid>
            </Border>
        </Grid>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  KPI CARDS — 2x2 Grid Optimized for Mobile  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Grid Grid.Row="1"
              Margin="6,6,6,0"
              ColumnDefinitions="*, *"
              RowDefinitions="Auto, Auto"
              ColumnSpacing="5"
              RowSpacing="5">
            <!--  KPI: PRESENTES  -->
            <Border Grid.Row="0"
                    Grid.Column="0"
                    Style="{StaticResource StatCardStyle}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#F0FDF4" />
                        <GradientStop Offset="1" Color="#FFFFFF" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border HeightRequest="3"
                            HorizontalOptions="Fill"
                            VerticalOptions="Start"
                            StrokeThickness="0"
                            BackgroundColor="#20C55E"
                            StrokeShape="RoundRectangle 12,12,0,0" />
                    <VerticalStackLayout Padding="6,6,6,5" Spacing="2">
                        <Label Text="{Binding TotalAsistentes}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#16A34A"
                               HorizontalOptions="Start"
                               LineHeight="1" />
                        <Border HeightRequest="2"
                                WidthRequest="18"
                                HorizontalOptions="Start"
                                BackgroundColor="#BBF7D0"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 1" />
                        <Label Text="PRESENTES"
                               FontSize="7.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="1" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  KPI: TOTAL EMPLEADOS  -->
            <Border Grid.Row="0"
                    Grid.Column="1"
                    Style="{StaticResource StatCardStyle}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#EFF6FF" />
                        <GradientStop Offset="1" Color="#FFFFFF" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border HeightRequest="3"
                            HorizontalOptions="Fill"
                            VerticalOptions="Start"
                            StrokeThickness="0"
                            BackgroundColor="#3B82F6"
                            StrokeShape="RoundRectangle 12,12,0,0" />
                    <VerticalStackLayout Padding="6,6,6,5" Spacing="2">
                        <Label Text="{Binding TotalInvitados}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#2563A8"
                               HorizontalOptions="Start"
                               LineHeight="1" />
                        <Border HeightRequest="2"
                                WidthRequest="20"
                                HorizontalOptions="Start"
                                BackgroundColor="#BFDBFE"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 1" />
                        <Label Text="TOTAL EMP."
                               FontSize="8"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="1" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  KPI: % ASISTENCIA  -->
            <Border Grid.Row="1"
                    Grid.Column="0"
                    Style="{StaticResource StatCardStyle}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#FFF7ED" />
                        <GradientStop Offset="1" Color="#FFFFFF" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border HeightRequest="3"
                            HorizontalOptions="Fill"
                            VerticalOptions="Start"
                            StrokeThickness="0"
                            BackgroundColor="#F97316"
                            StrokeShape="RoundRectangle 12,12,0,0" />
                    <VerticalStackLayout Padding="6,6,6,5" Spacing="2">
                        <Label Text="{Binding PorcentajeAsistencia}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#EA580C"
                               HorizontalOptions="Start"
                               LineHeight="1" />
                        <Border HeightRequest="2"
                                WidthRequest="18"
                                HorizontalOptions="Start"
                                BackgroundColor="#FED7AA"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 1" />
                        <Label Text="ASISTENCIA"
                               FontSize="7.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="1" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  KPI: PRECISIÓN  -->
            <Border Grid.Row="1"
                    Grid.Column="1"
                    Style="{StaticResource StatCardStyle}">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                        <GradientStop Offset="0" Color="#FAF5FF" />
                        <GradientStop Offset="1" Color="#FFFFFF" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Border HeightRequest="3"
                            HorizontalOptions="Fill"
                            VerticalOptions="Start"
                            StrokeThickness="0"
                            BackgroundColor="#8B5CF6"
                            StrokeShape="RoundRectangle 12,12,0,0" />
                    <VerticalStackLayout Padding="6,6,6,5" Spacing="2">
                        <Label Text="{Binding PorcentajeAsistenciaDecimal}"
                               FontSize="20"
                               FontAttributes="Bold"
                               TextColor="#7C3AED"
                               HorizontalOptions="Start"
                               VerticalOptions="Center"
                               LineHeight="1" />
                        <Border HeightRequest="2"
                                WidthRequest="18"
                                HorizontalOptions="Start"
                                BackgroundColor="#DDD6FE"
                                StrokeThickness="0"
                                StrokeShape="RoundRectangle 1" />
                        <Label Text="PRECISIÓN"
                               FontSize="7.5"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="1" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  SEARCH BAR — Compact Search for Mobile  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Border Grid.Row="2"
                Margin="6,5,6,5"
                Padding="1"
                BackgroundColor="#FFFFFF"
                Stroke="{StaticResource NeutralBorder}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                Shadow="{StaticResource Elevation1}">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="0">
                <SearchBar Grid.Column="0"
                           Placeholder="Buscar por nombre, dept. o nómina..."
                           Text="{Binding TextoBusqueda}"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{StaticResource HRPrimary}"
                           PlaceholderColor="#94A3B8"
                           TextColor="{StaticResource BodyText}"
                           FontSize="12.5"
                           HeightRequest="20">
                    <SearchBar.Margin>
                        <OnPlatform x:TypeArguments="Thickness">
                            <On Platform="iOS" Value="5,0,0,0" />
                            <On Platform="Android" Value="2,0,0,0" />
                        </OnPlatform>
                    </SearchBar.Margin>
                </SearchBar>
                <Border Grid.Column="1"
                        Margin="0,5,5,5"
                        Padding="0"
                        BackgroundColor="{StaticResource NeutralBg}"
                        Stroke="{StaticResource NeutralBorder}"
                        StrokeThickness="0.5"
                        WidthRequest="30"
                        HeightRequest="30"
                        VerticalOptions="Center"
                        StrokeShape="RoundRectangle 6"
                        IsVisible="{Binding TextoBusqueda, Converter={StaticResource NullToBoolConverter}}">
                    <Button Margin="0"
                            Text="✕"
                            Command="{Binding LimpiarBusquedaCommand}"
                            BackgroundColor="Transparent"
                            TextColor="{StaticResource MutedText}"
                            FontSize="11"
                            WidthRequest="30"
                            HeightRequest="30"
                            CornerRadius="6" />
                </Border>
            </Grid>
        </Border>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  FILTERS — Segmented Control  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Border Grid.Row="3"
                Margin="6,5,6,0"
                Padding="8,6"
                Style="{StaticResource CardStyle}"
                Shadow="{StaticResource SubtleShadow}">
            <Grid ColumnDefinitions="*, *, *, Auto" ColumnSpacing="6">
                <Button Grid.Column="0"
                        Text="Todos"
                        Command="{Binding FiltrarTodosCommand}"
                        BackgroundColor="{Binding FiltroSeleccionado, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Todos}"
                        TextColor="#1E293B"
                        Style="{StaticResource FilterButtonStyle}" />
                <Button Grid.Column="1"
                        Text="Presentes"
                        Command="{Binding FiltrarPresentesCommand}"
                        BackgroundColor="{Binding FiltroSeleccionado, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Presentes}"
                        TextColor="#1E293B"
                        Style="{StaticResource FilterButtonStyle}" />
                <Button Grid.Column="2"
                        Text="Ausentes"
                        Command="{Binding FiltrarAusentesCommand}"
                        BackgroundColor="{Binding FiltroSeleccionado, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Ausentes}"
                        TextColor="#1E293B"
                        Style="{StaticResource FilterButtonStyle}" />
                <!--  Count Badge  -->
                <Border Grid.Column="3"
                        Padding="0"
                        BackgroundColor="Transparent"
                        StrokeThickness="0"
                        HeightRequest="30"
                        VerticalOptions="Center"
                        HorizontalOptions="End">
                    <Label Text="{Binding InvitadosFiltrados.Count, StringFormat='{0} reg.'}"
                           TextColor="{StaticResource MutedText}"
                           FontSize="10"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center"
                           CharacterSpacing="0.2" />
                </Border>
            </Grid>
        </Border>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  EMPLOYEE LIST — Main Scrollable Area  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <CollectionView Grid.Row="4"
                        Margin="7,5,7,0"
                        ItemsSource="{Binding InvitadosFiltrados}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="6" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,0,0,0"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource CardBorder}"
                            StrokeThickness="0.5"
                            StrokeShape="RoundRectangle 12"
                            Shadow="{StaticResource CardHoverShadow}">
                        <Grid ColumnDefinitions="4, Auto, *, Auto">
                            <!--  Status Indicator Bar  -->
                            <Border Grid.Column="0"
                                    Margin="4,5,0,5"
                                    BackgroundColor="{Binding Asistio, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Background'}"
                                    StrokeThickness="0"
                                    WidthRequest="4"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill"
                                    StrokeShape="RoundRectangle 2" />
                            <!--  Avatar  -->
                            <Border Grid.Column="1"
                                    Margin="4,5,0,5"
                                    Padding="0"
                                    BackgroundColor="{Binding Asistio, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Indicator'}"
                                    HeightRequest="42"
                                    WidthRequest="42"
                                    VerticalOptions="Center"
                                    StrokeThickness="2"
                                    Stroke="#FFFFFF"
                                    StrokeShape="RoundRectangle 21">
                                <Label Text="{Binding Nomina}"
                                       TextColor="White"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <!--  Employee Info  -->
                            <VerticalStackLayout Grid.Column="2"
                                                 Padding="5,5,0,5"
                                                 Spacing="2">
                                <Label Text="{Binding Nombre}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource HeaderText}"
                                       LineHeight="1.2" />
                                <!--  Department & Supervisor Row  -->
                                <HorizontalStackLayout Spacing="3">
                                    <Label Text="{Binding Departamento}"
                                           FontSize="11"
                                           TextColor="{StaticResource MutedText}" />
                                    <Label Text="·"
                                           FontSize="11"
                                           TextColor="#CBD5E1"
                                           IsVisible="{Binding Supervisor, Converter={StaticResource NullToBoolConverter}}" />
                                    <Label Text="{Binding Supervisor}"
                                           FontSize="11"
                                           TextColor="#94A3B8"
                                           IsVisible="{Binding Supervisor, Converter={StaticResource NullToBoolConverter}}" />
                                </HorizontalStackLayout>
                                <!--  Check-in Time Chip  -->
                                <Border Margin="0,3,0,0"
                                        Padding="6,3"
                                        BackgroundColor="{StaticResource SuccessBg}"
                                        Stroke="{StaticResource SuccessBorder}"
                                        StrokeThickness="0.5"
                                        StrokeShape="RoundRectangle 5"
                                        HorizontalOptions="Start"
                                        IsVisible="{Binding Asistio}">
                                    <Label Text="{Binding HoraCheckIn, StringFormat='✓ {0:HH:mm}'}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource SuccessGreen}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding RegistroForzado}"
                                                         Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource WarnAmber}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding RegistroForzado}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource WarnBg}" />
                                            <Setter Property="Stroke" Value="{StaticResource WarnBorder}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </VerticalStackLayout>
                            <!--  Status Badge  -->
                            <Border Grid.Column="3"
                                    Margin="0,0,5,0"
                                    Padding="5,4"
                                    BackgroundColor="{Binding Asistio, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Background'}"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End"
                                    StrokeShape="RoundRectangle 8">
                                <Label Text="{Binding RegistroForzado, Converter={StaticResource BoolToStringConverter}, ConverterParameter='⚠,⏳,✓'}"
                                       TextColor="{Binding RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Indicator'}"
                                       FontSize="13"
                                       FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="12,24"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="8">
                    <!--  Empty State Icon  -->
                    <Border Padding="10"
                            BackgroundColor="#F8FAFC"
                            Stroke="{StaticResource NeutralBorder}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 25"
                            HorizontalOptions="Center"
                            Shadow="{StaticResource Elevation1}">
                        <Label Text="📋"
                               FontSize="32"
                               HorizontalOptions="Center" />
                    </Border>
                    <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                        <Label Text="Sin resultados"
                               FontSize="16"
                               FontAttributes="Bold"
                               TextColor="{StaticResource HeaderText}"
                               HorizontalOptions="Center" />
                        <Label Text="Ajusta los filtros o búsqueda"
                               FontSize="12"
                               TextColor="{StaticResource MutedText}"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  ACTION TOOLBAR — Compact Bottom Bar  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Border x:Name="ToolbarBorder"
                Grid.Row="5"
                Margin="6,5,6,0"
                Padding="10,8"
                BackgroundColor="#FFFFFF"
                Stroke="{StaticResource CardBorder}"
                StrokeThickness="0.5"
                StrokeShape="RoundRectangle 12"
                Shadow="{StaticResource Elevation2}">
            <VerticalStackLayout Spacing="6">
                <!--  Status Message  -->
                <Border Padding="8,5"
                        BackgroundColor="#F8FAFC"
                        Stroke="{StaticResource NeutralBorder}"
                        StrokeThickness="0.5"
                        StrokeShape="RoundRectangle 6">
                    <Label Text="{Binding StatusMessage}"
                           FontSize="10"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource MutedText}"
                           CharacterSpacing="0.1" />
                </Border>
                <!--  Action Buttons Grid  -->
                <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="6">
                    <!--  Load File  -->
                    <Border Grid.Column="0"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Shadow="{StaticResource Elevation1}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#16A34A" />
                                <GradientStop Offset="1" Color="#15803D" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Text="📂"
                                Command="{Binding CargarExcelCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                Style="{StaticResource ActionBtnStyle}" />
                    </Border>
                    <!--  Scan QR  -->
                    <Border Grid.Column="1"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Shadow="{StaticResource Elevation1}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#2563A8" />
                                <GradientStop Offset="1" Color="#1A4B7A" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Text="📷"
                                Command="{Binding EscanearQRCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                Style="{StaticResource ActionBtnStyle}" />
                    </Border>
                    <!--  Export Report  -->
                    <Border Grid.Column="2"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Shadow="{StaticResource Elevation1}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#F0920A" />
                                <GradientStop Offset="1" Color="#E07B1A" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Text="📊"
                                Command="{Binding ExportarReporteCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                Style="{StaticResource ActionBtnStyle}" />
                    </Border>
                    <!--  Clear Data  -->
                    <Border Grid.Column="3"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 10"
                            Shadow="{StaticResource Elevation1}">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                <GradientStop Offset="0" Color="#EF4444" />
                                <GradientStop Offset="1" Color="#DC2626" />
                            </LinearGradientBrush>
                        </Border.Background>
                        <Button Text="🗑️"
                                Command="{Binding LimpiarAplicacionCommand}"
                                BackgroundColor="Transparent"
                                TextColor="White"
                                Style="{StaticResource ActionBtnStyle}" />
                    </Border>
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  DETAIL PANEL — Bottom Sheet Armonizado  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Grid x:Name="OverlayGrid"
              Grid.RowSpan="7"
              IsVisible="{Binding InvitadoSeleccionado, Converter={StaticResource NullToBoolConverter}}"
              InputTransparent="True"
              CascadeInputTransparent="False">

            <!--  BACKDROP (con opacidad animable)  -->
            <BoxView x:Name="Backdrop"
                     BackgroundColor="Black"
                     Opacity="0.0"
                     InputTransparent="True" />

            <!--  BOTTOM SHEET  -->
            <Border x:Name="DetailSheet"
                    Padding="24,20,24,24"
                    VerticalOptions="End"
                    BackgroundColor="{StaticResource CardBg}"
                    Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1.2"
                    StrokeShape="RoundRectangle 28,28,0,0"
                    TranslationY="0"
                    InputTransparent="False"
                    Shadow="{StaticResource Elevation3}">


                <Border.GestureRecognizers>
                    <PanGestureRecognizer PanUpdated="OnPanUpdated" />
                </Border.GestureRecognizers>

                <!--  Permitir scroll si el contenido lo requiere  -->
                <ScrollView VerticalScrollBarVisibility="Default">
                    <VerticalStackLayout Spacing="20">

                        <!--  HANDLE  -->
                        <BoxView HeightRequest="5"
                                 WidthRequest="44"
                                 CornerRadius="2.5"
                                 BackgroundColor="{StaticResource OutlineVariant}"
                                 Opacity="0.7"
                                 HorizontalOptions="Center" />

                        <!--  ── SECCIÓN: ESTADO DEL CHECK-IN ──  -->
                        <VerticalStackLayout Spacing="8" HorizontalOptions="Center">
                            <!--  Icono de estado (usando símbolos coherentes con la lista)  -->
                            <Border WidthRequest="56"
                                    HeightRequest="56"
                                    BackgroundColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Background'}"
                                    Stroke="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Indicator'}"
                                    StrokeThickness="2"
                                    StrokeShape="RoundRectangle 28"
                                    HorizontalOptions="Center"
                                    Shadow="{StaticResource Elevation1}">
                                <Label Text="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToStringConverter}, ConverterParameter='⚠,⏳,✓'}"
                                       FontSize="24"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center"
                                       TextColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Text'}" />
                            </Border>

                            <Label Text="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToStringConverter}, ConverterParameter='REGISTRO FORZADO,CHECK-IN EXITOSO'}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   HorizontalOptions="Center"
                                   CharacterSpacing="0.5"
                                   TextColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Text'}" />
                        </VerticalStackLayout>

                        <!--  SEPARADOR DÚCTIL  -->
                        <BoxView HeightRequest="1"
                                 Opacity="0.4"
                                 Color="{StaticResource DividerColor}" />

                        <!--  ── SECCIÓN: IDENTIDAD DEL EMPLEADO ──  -->
                        <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                            <Label Text="{Binding InvitadoSeleccionado.Nombre}"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="{StaticResource HeaderText}"
                                   HorizontalTextAlignment="Center"
                                   LineHeight="1.2" />

                            <!--  Departamento · Supervisor  -->
                            <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                                <Label Text="{Binding InvitadoSeleccionado.Departamento}"
                                       FontSize="13"
                                       TextColor="{StaticResource MutedText}" />
                                <Label Text="·"
                                       TextColor="{StaticResource OutlineVariant}"
                                       VerticalOptions="Center" />
                                <Label Text="{Binding InvitadoSeleccionado.Supervisor}"
                                       FontSize="13"
                                       TextColor="{StaticResource MutedText}" />
                            </HorizontalStackLayout>

                            <!--  Hora de registro con estilo chip  -->
                            <Border Margin="0,6,0,0"
                                    Padding="10,5"
                                    BackgroundColor="{StaticResource NeutralBg}"
                                    Stroke="{StaticResource NeutralBorder}"
                                    StrokeThickness="0.8"
                                    StrokeShape="RoundRectangle 8"
                                    HorizontalOptions="Center">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="🕒" FontSize="12" />
                                    <Label Text="{Binding InvitadoSeleccionado.HoraCheckIn, StringFormat='{0:HH:mm:ss}'}"
                                           FontSize="13"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource BodyText}" />
                                </HorizontalStackLayout>
                            </Border>
                        </VerticalStackLayout>

                        <!--  ── SECCIÓN: DESPENSA ──  -->
                        <Border Padding="14"
                                BackgroundColor="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Background'}"
                                Stroke="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Indicator'}"
                                StrokeThickness="1.2"
                                StrokeShape="RoundRectangle 16"
                                Shadow="{StaticResource SubtleShadow}">
                            <HorizontalStackLayout Spacing="10" HorizontalOptions="Center">
                                <!--  Mini indicador  -->
                                <Border WidthRequest="10"
                                        HeightRequest="10"
                                        BackgroundColor="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Indicator'}"
                                        StrokeThickness="0"
                                        StrokeShape="RoundRectangle 5"
                                        VerticalOptions="Center" />
                                <Label Text="{Binding InvitadoSeleccionado.EstadoDerecho}"
                                       FontSize="15"
                                       FontAttributes="Bold"
                                       VerticalOptions="Center"
                                       TextColor="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Text'}" />
                            </HorizontalStackLayout>
                        </Border>

                        <!--  ── ADVERTENCIA (solo si es forzado) ──  -->
                        <Border Padding="12,10"
                                IsVisible="{Binding InvitadoSeleccionado.RegistroForzado}"
                                BackgroundColor="{StaticResource WarnBg}"
                                Stroke="{StaticResource WarnBorder}"
                                StrokeThickness="0.8"
                                StrokeShape="RoundRectangle 10">
                            <Label Text="⚠️ Este empleado NO tiene derecho a despensa. Registro autorizado manualmente."
                                   FontSize="12"
                                   TextColor="{StaticResource WarnAmber}"
                                   HorizontalTextAlignment="Center"
                                   LineHeight="1.3" />
                        </Border>

                        <!--  ── ACCIONES ──  -->
                        <Grid Margin="0,6,0,0"
                              ColumnDefinitions="*,*"
                              ColumnSpacing="12">
                            <!--  Botón secundario (Limpiar)  -->
                            <Button Text="Limpiar"
                                    Command="{Binding LimpiarResultadoCommand}"
                                    BackgroundColor="Transparent"
                                    TextColor="{StaticResource DangerRed}"
                                    BorderColor="{StaticResource DangerBorder}"
                                    BorderWidth="1.5"
                                    CornerRadius="14"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    HeightRequest="50" />

                            <!--  Botón primario (Exportar)  -->
                            <Button Text="Exportar Todo"
                                    Command="{Binding ExportarReporteCommand}"
                                    BackgroundColor="{StaticResource HRPrimary}"
                                    TextColor="White"
                                    CornerRadius="14"
                                    FontAttributes="Bold"
                                    FontSize="13"
                                    HeightRequest="50"
                                    Shadow="{StaticResource Elevation1}" />
                        </Grid>

                    </VerticalStackLayout>
                </ScrollView>
            </Border>

            <Grid.GestureRecognizers>
                <PanGestureRecognizer PanUpdated="OnPanUpdated" />
            </Grid.GestureRecognizers>
        </Grid>



        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  LOADING OVERLAY — Compact Loading Modal  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Grid Grid.RowSpan="7"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#CC000000">
            <BoxView HorizontalOptions="Fill"
                     VerticalOptions="Fill"
                     Opacity="0.2"
                     BackgroundColor="#0F2E4D" />
            <Border Padding="28,24"
                    BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource NeutralBorder}"
                    StrokeThickness="0.5"
                    StrokeShape="RoundRectangle 16"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Shadow="{StaticResource Elevation3}">
                <VerticalStackLayout Spacing="14" HorizontalOptions="Center">
                    <!--  Spinner Container  -->
                    <Border WidthRequest="44"
                            HeightRequest="44"
                            BackgroundColor="#F8FAFC"
                            Stroke="{StaticResource NeutralBorder}"
                            StrokeThickness="0.5"
                            StrokeShape="RoundRectangle 22"
                            HorizontalOptions="Center">
                        <ActivityIndicator IsRunning="True"
                                           HeightRequest="40"
                                           WidthRequest="40"
                                           HorizontalOptions="Center"
                                           VerticalOptions="Center"
                                           Color="{StaticResource HRPrimary}" />
                    </Border>
                    <VerticalStackLayout Spacing="3" HorizontalOptions="Center">
                        <Label Text="Procesando..."
                               TextColor="{StaticResource HeaderText}"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               CharacterSpacing="0.4" />
                        <Label Text="Por favor espera"
                               FontSize="10"
                               TextColor="{StaticResource MutedText}"
                               HorizontalOptions="Center" />
                    </VerticalStackLayout>
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!--  ═══════════════════════════════════════════════════════════════  -->
        <!--  QR SCANNER OVERLAY — Full Screen Camera View  -->
        <!--  ═══════════════════════════════════════════════════════════════  -->
        <Grid Grid.RowSpan="7"
              IsVisible="{Binding IsScanning}"
              BackgroundColor="#E6000000">
            <zxing:CameraBarcodeReaderView x:Name="barcodeReader"
                                           BarcodesDetected="BarcodesDetected"
                                           IsDetecting="True" />
            <!--  Edge Vignette  -->
            <Border HorizontalOptions="Fill"
                    VerticalOptions="Fill"
                    StrokeThickness="45"
                    Stroke="#99000000"
                    StrokeShape="RoundRectangle 0"
                    BackgroundColor="Transparent" />
            <!--  Top Instruction Badge  -->
            <Border Margin="0,56,0,0"
                    Padding="20,10"
                    BackgroundColor="#F0FFFFFF"
                    Stroke="#20FFFFFF"
                    StrokeThickness="0.5"
                    StrokeShape="RoundRectangle 24"
                    HorizontalOptions="Center"
                    VerticalOptions="Start"
                    Shadow="{StaticResource Elevation2}">
                <HorizontalStackLayout Spacing="10"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center">
                    <Border WidthRequest="6"
                            HeightRequest="6"
                            BackgroundColor="#E07B1A"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 3"
                            VerticalOptions="Center">
                        <Border.Shadow>
                            <Shadow Brush="#E07B1A"
                                    Opacity="0.4"
                                    Radius="4"
                                    Offset="0,0" />
                        </Border.Shadow>
                    </Border>
                    <VerticalStackLayout Spacing="1">
                        <Label Text="ESCANEAR CÓDIGO"
                               FontSize="9"
                               FontAttributes="Bold"
                               TextColor="{StaticResource HRPrimary}"
                               CharacterSpacing="1.5" />
                        <Label Text="Apunta al código QR del empleado"
                               FontSize="11"
                               TextColor="{StaticResource BodyText}" />
                    </VerticalStackLayout>
                </HorizontalStackLayout>
            </Border>
            <!--  Scan Frame  -->
            <Grid HorizontalOptions="Center"
                  VerticalOptions="Center"
                  HeightRequest="260"
                  WidthRequest="260">
                <!--  Inner Background  -->
                <Border BackgroundColor="#08FFFFFF"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 20"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                <!--  Outer Frame  -->
                <Border Stroke="#40FFFFFF"
                        StrokeThickness="0.5"
                        BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 20"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                <!--  Corner: Top-Left  -->
                <Border WidthRequest="36"
                        HeightRequest="36"
                        HorizontalOptions="Start"
                        VerticalOptions="Start"
                        Stroke="#E07B1A"
                        StrokeThickness="3"
                        BackgroundColor="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="5,0,0,0" />
                    </Border.StrokeShape>
                </Border>
                <!--  Corner: Top-Right  -->
                <Border WidthRequest="36"
                        HeightRequest="36"
                        HorizontalOptions="End"
                        VerticalOptions="Start"
                        Stroke="#E07B1A"
                        StrokeThickness="3"
                        BackgroundColor="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,5,0,0" />
                    </Border.StrokeShape>
                </Border>
                <!--  Corner: Bottom-Left  -->
                <Border WidthRequest="36"
                        HeightRequest="36"
                        HorizontalOptions="Start"
                        VerticalOptions="End"
                        Stroke="#E07B1A"
                        StrokeThickness="3"
                        BackgroundColor="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,0,5" />
                    </Border.StrokeShape>
                </Border>
                <!--  Corner: Bottom-Right  -->
                <Border WidthRequest="36"
                        HeightRequest="36"
                        HorizontalOptions="End"
                        VerticalOptions="End"
                        Stroke="#E07B1A"
                        StrokeThickness="3"
                        BackgroundColor="Transparent">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="0,0,5,0" />
                    </Border.StrokeShape>
                </Border>
                <!--  Scan Line  -->
                <BoxView HeightRequest="1.5"
                         HorizontalOptions="Fill"
                         VerticalOptions="Center"
                         Opacity="0.7"
                         Background="{StaticResource ScannerLineGradient}" />
            </Grid>
            <!--  Cancel Button  -->
            <Border Margin="0,0,0,48"
                    Padding="0"
                    BackgroundColor="#F0FFFFFF"
                    Stroke="#20FFFFFF"
                    StrokeThickness="0.5"
                    StrokeShape="RoundRectangle 26"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Shadow="{StaticResource Elevation2}">
                <Button Text="✕ Cancelar"
                        Clicked="OnCancelScanClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource DangerRed}"
                        CornerRadius="26"
                        WidthRequest="150"
                        HeightRequest="52"
                        FontAttributes="Bold"
                        FontSize="12.5"
                        CharacterSpacing="0.3" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>
