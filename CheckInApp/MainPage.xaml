<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:viewmodels="clr-namespace:CheckInApp.ViewModels"
             xmlns:converters="clr-namespace:CheckInApp.Converters"
             xmlns:zxing="clr-namespace:ZXing.Net.Maui.Controls;assembly=ZXing.Net.MAUI.Controls"
             x:Class="CheckInApp.MainPage"
             Title="Check-In Empleados"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#F0F4F8">

    <ContentPage.Resources>
        <ResourceDictionary>
            <!--  ── Material / Brand Colors ──  -->
            <Color x:Key="Primary">#6750A4</Color>
            <Color x:Key="OnPrimary">#FFFFFF</Color>
            <Color x:Key="PrimaryContainer">#EADDFF</Color>
            <Color x:Key="OnPrimaryContainer">#21005D</Color>
            <Color x:Key="Secondary">#625B71</Color>
            <Color x:Key="OnSecondary">#FFFFFF</Color>
            <Color x:Key="SecondaryContainer">#E8DEF8</Color>
            <Color x:Key="OnSecondaryContainer">#1D192B</Color>
            <Color x:Key="Tertiary">#7D5260</Color>
            <Color x:Key="OnTertiary">#FFFFFF</Color>
            <Color x:Key="TertiaryContainer">#FFD8E4</Color>
            <Color x:Key="OnTertiaryContainer">#31111D</Color>
            <Color x:Key="Error">#B3261E</Color>
            <Color x:Key="OnError">#FFFFFF</Color>
            <Color x:Key="ErrorContainer">#F9DEDC</Color>
            <Color x:Key="OnErrorContainer">#410E0B</Color>
            <Color x:Key="Surface">#FEF7FF</Color>
            <Color x:Key="OnSurface">#1D1B20</Color>
            <Color x:Key="SurfaceVariant">#E7E0EC</Color>
            <Color x:Key="OnSurfaceVariant">#49454F</Color>
            <Color x:Key="Outline">#79747E</Color>
            <Color x:Key="OutlineVariant">#CAC4D0</Color>
            <Color x:Key="InverseSurface">#322F35</Color>
            <Color x:Key="InverseOnSurface">#F5EFF7</Color>
            <Color x:Key="InversePrimary">#D0BCFF</Color>
            <Color x:Key="Shadow">#000000</Color>
            <Color x:Key="SurfaceTint">#6750A4</Color>
            <Color x:Key="Scrim">#000000</Color>
            <!--  ── HR Corporate Palette ──  -->
            <Color x:Key="HRPrimary">#1A4B7A</Color>
            <Color x:Key="HRPrimaryDark">#0F2E4D</Color>
            <Color x:Key="HRPrimaryLight">#2563A8</Color>
            <Color x:Key="HRAccent">#E07B1A</Color>
            <Color x:Key="HRAccentLight">#F0922A</Color>
            <Color x:Key="PageBg">#F0F4F8</Color>
            <Color x:Key="CardBg">#FFFFFF</Color>
            <Color x:Key="CardBorder">#E2E8F0</Color>
            <Color x:Key="HeaderText">#0F2E4D</Color>
            <Color x:Key="BodyText">#334155</Color>
            <Color x:Key="MutedText">#64748B</Color>
            <Color x:Key="DividerColor">#E2E8F0</Color>
            <!--  ── Status Colors ──  -->
            <Color x:Key="SuccessGreen">#15803D</Color>
            <Color x:Key="SuccessBg">#DCFCE7</Color>
            <Color x:Key="SuccessBorder">#86EFAC</Color>
            <Color x:Key="DangerRed">#B91C1C</Color>
            <Color x:Key="DangerBg">#FEE2E2</Color>
            <Color x:Key="DangerBorder">#FCA5A5</Color>
            <Color x:Key="WarnAmber">#B45309</Color>
            <Color x:Key="WarnBg">#FEF3C7</Color>
            <Color x:Key="WarnBorder">#FCD34D</Color>
            <Color x:Key="InfoBlue">#1D4ED8</Color>
            <Color x:Key="InfoBg">#DBEAFE</Color>
            <Color x:Key="InfoBorder">#93C5FD</Color>
            <Color x:Key="NeutralBg">#F1F5F9</Color>
            <Color x:Key="NeutralBorder">#CBD5E1</Color>
            <!--  ── Semantic (kept for converters) ──  -->
            <Color x:Key="Success">#4CAF50</Color>
            <Color x:Key="OnSuccess">#FFFFFF</Color>
            <Color x:Key="Warning">#FF9800</Color>
            <Color x:Key="OnWarning">#FFFFFF</Color>
            <Color x:Key="Info">#2196F3</Color>
            <Color x:Key="OnInfo">#FFFFFF</Color>
            <!--  ── Gradients ──  -->
            <LinearGradientBrush x:Key="SuccessGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#4CAF50" />
                <GradientStop Offset="1" Color="#81C784" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="WarningGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#FF9800" />
                <GradientStop Offset="1" Color="#FFB74D" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="InfoGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#2196F3" />
                <GradientStop Offset="1" Color="#64B5F6" />
            </LinearGradientBrush>
            <LinearGradientBrush x:Key="AccentGradient" StartPoint="0,0" EndPoint="1,1">
                <GradientStop Offset="0" Color="#9C27B0" />
                <GradientStop Offset="1" Color="#CE93D8" />
            </LinearGradientBrush>
            <!--  ── Shadows ──  -->
            <Shadow x:Key="Elevation1"
                    Brush="#64748B"
                    Opacity="0.10"
                    Radius="6"
                    Offset="0,2" />
            <Shadow x:Key="Elevation2"
                    Brush="#64748B"
                    Opacity="0.13"
                    Radius="12"
                    Offset="0,4" />
            <Shadow x:Key="Elevation3"
                    Brush="#0F2E4D"
                    Opacity="0.18"
                    Radius="20"
                    Offset="0,6" />
            <!--  ── Styles ──  -->
            <Style x:Key="CardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
                <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="Shadow" Value="{StaticResource Elevation1}" />
            </Style>
            <Style x:Key="StatCardStyle" TargetType="Border">
                <Setter Property="BackgroundColor" Value="{StaticResource CardBg}" />
                <Setter Property="StrokeShape" Value="RoundRectangle 12" />
                <Setter Property="StrokeThickness" Value="1" />
                <Setter Property="Stroke" Value="{StaticResource CardBorder}" />
                <Setter Property="Shadow" Value="{StaticResource Elevation1}" />
                <Setter Property="Padding" Value="0" />
            </Style>
            <Style x:Key="FilterButtonStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="8" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="HeightRequest" Value="34" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="0.2" />
            </Style>
            <Style x:Key="ActionBtnStyle" TargetType="Button">
                <Setter Property="CornerRadius" Value="10" />
                <Setter Property="HeightRequest" Value="48" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="CharacterSpacing" Value="0.3" />
                <Setter Property="Shadow" Value="{StaticResource Elevation1}" />
            </Style>
            <Style x:Key="SectionTitleStyle" TargetType="Label">
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontAttributes" Value="Bold" />
                <Setter Property="TextColor" Value="{StaticResource MutedText}" />
                <Setter Property="CharacterSpacing" Value="1.2" />
            </Style>
            <!--  ── Converters ──  -->
            <converters:BoolToColorConverter x:Key="BoolToColorConverter" />
            <converters:NullToBoolConverter x:Key="NullToBoolConverter" />
            <converters:InverseBoolConverter x:Key="InverseBoolConverter" />
            <converters:BoolToStringConverter x:Key="BoolToStringConverter" />
        </ResourceDictionary>
    </ContentPage.Resources>

    <ContentPage.BindingContext>
        <viewmodels:MainViewModel />
    </ContentPage.BindingContext>

    <Grid RowDefinitions="Auto, Auto, Auto, Auto, *, Auto, Auto" RowSpacing="0">

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  HEADER — Barra corporativa HR  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Grid Grid.Row="0">
            <Border Padding="0" StrokeThickness="0">
                <Border.Background>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                        <GradientStop Offset="0.0" Color="#0F2E4D" />
                        <GradientStop Offset="0.6" Color="#1A4B7A" />
                        <GradientStop Offset="1.0" Color="#1E5490" />
                    </LinearGradientBrush>
                </Border.Background>
                <Grid RowDefinitions="Auto, 3">
                    <Grid Padding="18,40,18,16" ColumnDefinitions="*, Auto">
                        <!--  Lado izquierdo: Título  -->
                        <VerticalStackLayout Grid.Column="0"
                                             Spacing="3"
                                             VerticalOptions="Center">
                            <Label Text="RECURSOS HUMANOS"
                                   FontSize="9"
                                   FontAttributes="Bold"
                                   TextColor="#93C5FD"
                                   CharacterSpacing="2.0" />
                            <Label Text="Control de Asistencia"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   TextColor="#FFFFFF"
                                   CharacterSpacing="0.3">
                                <Label.Shadow>
                                    <Shadow Brush="#000000"
                                            Opacity="0.2"
                                            Radius="4"
                                            Offset="0,2" />
                                </Label.Shadow>
                            </Label>
                            <Label Text="Check-In Industrial de Personal"
                                   FontSize="11"
                                   TextColor="#BFDBFE"
                                   CharacterSpacing="0.2" />
                        </VerticalStackLayout>
                        <!--  Lado derecho: badge sistema activo  -->
                        <Border Grid.Column="1"
                                Padding="10,6"
                                BackgroundColor="#0F2E4D"
                                Stroke="#2563A8"
                                StrokeThickness="1"
                                StrokeShape="RoundRectangle 8"
                                VerticalOptions="Center">
                            <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                                <Label Text="●  EN LÍNEA"
                                       FontSize="9"
                                       FontAttributes="Bold"
                                       TextColor="#4ADE80"
                                       CharacterSpacing="1.0"
                                       HorizontalOptions="Center" />
                                <Label Text="Sistema Activo"
                                       FontSize="8"
                                       TextColor="#93C5FD"
                                       HorizontalOptions="Center" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                    <!--  Línea de acento inferior naranja (color corporativo de acción)  -->
                    <BoxView Grid.Row="1"
                             HorizontalOptions="Fill"
                             VerticalOptions="Fill">
                        <BoxView.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                <GradientStop Offset="0" Color="#E07B1A" />
                                <GradientStop Offset="0.5" Color="#F0922A" />
                                <GradientStop Offset="1" Color="#E07B1A" />
                            </LinearGradientBrush>
                        </BoxView.Background>
                    </BoxView>
                </Grid>
            </Border>
        </Grid>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  ESTADÍSTICAS — 4 KPI cards estilo enterprise HR  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Grid Grid.Row="1"
              Margin="14,12,14,0"
              ColumnDefinitions="*, *, *, *"
              ColumnSpacing="8">

            <!--  KPI: PRESENTES  -->
            <Border Grid.Column="0" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <!--  Barra superior de color  -->
                    <BoxView HeightRequest="4"
                             HorizontalOptions="Fill"
                             VerticalOptions="Start"
                             CornerRadius="12,12,0,0"
                             BackgroundColor="#15803D" />
                    <VerticalStackLayout Padding="10,16,10,12" Spacing="4">
                        <!--  Valor principal  -->
                        <Label Text="{Binding TotalAsistentes}"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="#15803D"
                               HorizontalOptions="Start" />
                        <!--  Indicador: icono área  -->
                        <BoxView HeightRequest="2"
                                 WidthRequest="28"
                                 HorizontalOptions="Start"
                                 BackgroundColor="#86EFAC"
                                 CornerRadius="2" />
                        <Label Text="PRESENTES"
                               FontSize="9"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="0.8" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  KPI: TOTAL  -->
            <Border Grid.Column="1" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <BoxView HeightRequest="4"
                             HorizontalOptions="Fill"
                             VerticalOptions="Start"
                             CornerRadius="12,12,0,0"
                             BackgroundColor="#1A4B7A" />
                    <VerticalStackLayout Padding="10,16,10,12" Spacing="4">
                        <Label Text="{Binding TotalInvitados}"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="#1A4B7A"
                               HorizontalOptions="Start" />
                        <BoxView HeightRequest="2"
                                 WidthRequest="28"
                                 HorizontalOptions="Start"
                                 BackgroundColor="#93C5FD"
                                 CornerRadius="2" />
                        <Label Text="TOTAL EMP."
                               FontSize="9"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="0.8" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  KPI: % ASISTENCIA  -->
            <Border Grid.Column="2" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <BoxView HeightRequest="4"
                             HorizontalOptions="Fill"
                             VerticalOptions="Start"
                             CornerRadius="12,12,0,0"
                             BackgroundColor="#E07B1A" />
                    <VerticalStackLayout Padding="10,16,10,12" Spacing="4">
                        <Label Text="{Binding PorcentajeAsistencia}"
                               FontSize="30"
                               FontAttributes="Bold"
                               TextColor="#E07B1A"
                               HorizontalOptions="Start" />
                        <BoxView HeightRequest="2"
                                 WidthRequest="28"
                                 HorizontalOptions="Start"
                                 BackgroundColor="#FCD34D"
                                 CornerRadius="2" />
                        <Label Text="ASISTENCIA"
                               FontSize="9"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="0.8" />
                    </VerticalStackLayout>
                </Grid>
            </Border>

            <!--  KPI: PRECISIÓN  -->
            <Border Grid.Column="3" Style="{StaticResource StatCardStyle}">
                <Grid>
                    <BoxView HeightRequest="4"
                             HorizontalOptions="Fill"
                             VerticalOptions="Start"
                             CornerRadius="12,12,0,0"
                             BackgroundColor="#6D28D9" />
                    <VerticalStackLayout Padding="10,16,10,12" Spacing="4">
                        <Label Text="{Binding PorcentajeAsistenciaDecimal}"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#6D28D9"
                               HorizontalOptions="Start"
                               VerticalOptions="Center" />
                        <BoxView HeightRequest="2"
                                 WidthRequest="28"
                                 HorizontalOptions="Start"
                                 BackgroundColor="#C4B5FD"
                                 CornerRadius="2" />
                        <Label Text="PRECISIÓN"
                               FontSize="9"
                               FontAttributes="Bold"
                               TextColor="{StaticResource MutedText}"
                               CharacterSpacing="0.8" />
                    </VerticalStackLayout>
                </Grid>
            </Border>
        </Grid>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  BÚSQUEDA — Barra de búsqueda limpia estilo enterprise  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border Grid.Row="2"
                Margin="14,10,14,0"
                Padding="4,2"
                BackgroundColor="#FFFFFF"
                Stroke="{StaticResource CardBorder}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 10"
                Shadow="{StaticResource Elevation1}">
            <Grid ColumnDefinitions="*, Auto" ColumnSpacing="0">
                <SearchBar Grid.Column="0"
                           Placeholder="Buscar por nombre, departamento o nómina..."
                           Text="{Binding TextoBusqueda}"
                           BackgroundColor="Transparent"
                           CancelButtonColor="{StaticResource HRPrimary}"
                           PlaceholderColor="{StaticResource MutedText}"
                           TextColor="{StaticResource BodyText}"
                           FontSize="13"
                           HeightRequest="44">
                    <SearchBar.Margin>
                        <OnPlatform x:TypeArguments="Thickness">
                            <On Platform="iOS" Value="8,0,0,0" />
                            <On Platform="Android" Value="0" />
                        </OnPlatform>
                    </SearchBar.Margin>
                </SearchBar>
                <Button Grid.Column="1"
                        Margin="0,0,6,0"
                        Text="✕"
                        Command="{Binding LimpiarBusquedaCommand}"
                        BackgroundColor="{StaticResource NeutralBg}"
                        TextColor="{StaticResource MutedText}"
                        FontSize="13"
                        WidthRequest="34"
                        HeightRequest="34"
                        CornerRadius="6"
                        IsVisible="{Binding TextoBusqueda, Converter={StaticResource NullToBoolConverter}}" />
            </Grid>
        </Border>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  FILTROS — Tabs / segmented control estilo enterprise  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border Grid.Row="3"
                Margin="14,8,14,0"
                Padding="8,6"
                BackgroundColor="#FFFFFF"
                Stroke="{StaticResource CardBorder}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 10"
                Shadow="{StaticResource Elevation1}">
            <Grid ColumnDefinitions="*, *, *, Auto" ColumnSpacing="6">
                <Button Grid.Column="0"
                        Text="Todos"
                        Command="{Binding FiltrarTodosCommand}"
                        BackgroundColor="{Binding FiltroSeleccionado, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Todos}"
                        TextColor="Black"
                        Style="{StaticResource FilterButtonStyle}" />
                <Button Grid.Column="1"
                        Text="Presentes"
                        Command="{Binding FiltrarPresentesCommand}"
                        BackgroundColor="{Binding FiltroSeleccionado, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Presentes}"
                        TextColor="Black"
                        Style="{StaticResource FilterButtonStyle}" />
                <Button Grid.Column="2"
                        Text="Ausentes"
                        Command="{Binding FiltrarAusentesCommand}"
                        BackgroundColor="{Binding FiltroSeleccionado, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Ausentes}"
                        TextColor="Black"
                        Style="{StaticResource FilterButtonStyle}" />
                <!--  Badge contador  -->
                <Border Grid.Column="3"
                        Padding="10,0"
                        BackgroundColor="{StaticResource InfoBg}"
                        Stroke="{StaticResource InfoBorder}"
                        StrokeThickness="1"
                        HeightRequest="30"
                        VerticalOptions="Center"
                        HorizontalOptions="End">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="6" />
                    </Border.StrokeShape>
                    <Label Text="{Binding InvitadosFiltrados.Count, StringFormat='{0} reg.'}"
                           TextColor="{StaticResource InfoBlue}"
                           FontSize="11"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />
                </Border>
            </Grid>
        </Border>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LISTA DE EMPLEADOS — Tabla HR profesional  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <CollectionView Grid.Row="4"
                        Margin="14,8,14,0"
                        ItemsSource="{Binding InvitadosFiltrados}">
            <CollectionView.ItemsLayout>
                <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border Margin="0,1"
                            Padding="0"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource CardBorder}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 10"
                            Shadow="{StaticResource Elevation1}">
                        <Grid ColumnDefinitions="5, Auto, *, Auto">
                            <!--  Indicador lateral de estado  -->
                            <Border Grid.Column="0"
                                    BackgroundColor="{Binding Asistio, Converter={StaticResource BoolToColorConverter}, ConverterParameter=ID}"
                                    StrokeThickness="0"
                                    WidthRequest="5"
                                    HorizontalOptions="Fill"
                                    VerticalOptions="Fill">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="10,0,0,10" />
                                </Border.StrokeShape>
                            </Border>
                            <!--  Avatar: iniciales / nómina circular  -->
                            <Border Grid.Column="1"
                                    Margin="10,10,0,10"
                                    Padding="0"
                                    BackgroundColor="{Binding Asistio, Converter={StaticResource BoolToColorConverter}, ConverterParameter=ID}"
                                    HeightRequest="42"
                                    WidthRequest="42"
                                    VerticalOptions="Center"
                                    StrokeThickness="0">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="21" />
                                </Border.StrokeShape>
                                <Label Text="{Binding Nomina}"
                                       TextColor="White"
                                       FontSize="10"
                                       FontAttributes="Bold"
                                       HorizontalOptions="Center"
                                       VerticalOptions="Center" />
                            </Border>
                            <!--  Datos principales del empleado  -->
                            <VerticalStackLayout Grid.Column="2"
                                                 Padding="10,9,0,9"
                                                 Spacing="2">
                                <Label Text="{Binding Nombre}"
                                       FontSize="14"
                                       FontAttributes="Bold"
                                       TextColor="{StaticResource HeaderText}" />
                                <!--  Fila: departamento + separador + supervisor  -->
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding Departamento}"
                                           FontSize="12"
                                           TextColor="{StaticResource BodyText}" />
                                    <Label Text="·"
                                           FontSize="12"
                                           TextColor="{StaticResource MutedText}"
                                           IsVisible="{Binding Supervisor, Converter={StaticResource NullToBoolConverter}}" />
                                    <Label Text="{Binding Supervisor}"
                                           FontSize="12"
                                           TextColor="{StaticResource MutedText}"
                                           IsVisible="{Binding Supervisor, Converter={StaticResource NullToBoolConverter}}" />
                                </HorizontalStackLayout>
                                <!--  Hora de check-in (solo si asistió)  -->
                                <Border Padding="6,2"
                                        BackgroundColor="{StaticResource SuccessBg}"
                                        Stroke="{StaticResource SuccessBorder}"
                                        StrokeThickness="1"
                                        StrokeShape="RoundRectangle 4"
                                        HorizontalOptions="Start"
                                        IsVisible="{Binding Asistio}">
                                    <Label Text="{Binding HoraCheckIn, StringFormat='✓  Ingreso: {0:HH:mm}'}"
                                           FontSize="10"
                                           FontAttributes="Bold"
                                           TextColor="{StaticResource SuccessGreen}">
                                        <Label.Triggers>
                                            <DataTrigger TargetType="Label"
                                                         Binding="{Binding RegistroForzado}"
                                                         Value="True">
                                                <Setter Property="TextColor" Value="{StaticResource WarnAmber}" />
                                            </DataTrigger>
                                        </Label.Triggers>
                                    </Label>
                                    <Border.Triggers>
                                        <DataTrigger TargetType="Border"
                                                     Binding="{Binding RegistroForzado}"
                                                     Value="True">
                                            <Setter Property="BackgroundColor" Value="{StaticResource WarnBg}" />
                                            <Setter Property="Stroke" Value="{StaticResource WarnBorder}" />
                                        </DataTrigger>
                                    </Border.Triggers>
                                </Border>
                            </VerticalStackLayout>
                            <!--  Badge derecho: estado de asistencia  -->
                            <Border Grid.Column="3"
                                    Margin="0,0,10,0"
                                    Padding="10,7"
                                    BackgroundColor="{Binding Asistio, Converter={StaticResource BoolToColorConverter}, ConverterParameter=Background}"
                                    StrokeThickness="0"
                                    VerticalOptions="Center"
                                    HorizontalOptions="End">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="8" />
                                </Border.StrokeShape>
                                <Label Text="{Binding RegistroForzado, Converter={StaticResource BoolToStringConverter}, ConverterParameter='⚠️|✓'}"
                                       TextColor="{Binding RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Orange|Green'}"
                                       FontSize="16"
                                       FontAttributes="Bold" />
                            </Border>
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
            <CollectionView.EmptyView>
                <VerticalStackLayout Padding="32,52"
                                     HorizontalOptions="Center"
                                     VerticalOptions="Center"
                                     Spacing="12">
                    <Border Padding="20"
                            BackgroundColor="#FFFFFF"
                            Stroke="{StaticResource CardBorder}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 60"
                            HorizontalOptions="Center"
                            Shadow="{StaticResource Elevation1}">
                        <Label Text="○"
                               FontSize="36"
                               TextColor="{StaticResource MutedText}"
                               HorizontalOptions="Center"
                               VerticalOptions="Center" />
                    </Border>
                    <Label Text="Sin resultados"
                           FontSize="15"
                           FontAttributes="Bold"
                           TextColor="{StaticResource BodyText}"
                           HorizontalOptions="Center" />
                    <Label Text="Ajusta los filtros o el término de búsqueda"
                           FontSize="12"
                           TextColor="{StaticResource MutedText}"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
        </CollectionView>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  BARRA DE ACCIONES — Toolbar HR corporativo  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border Grid.Row="5"
                Margin="14,8,14,0"
                Padding="12,10"
                BackgroundColor="#FFFFFF"
                Stroke="{StaticResource CardBorder}"
                StrokeThickness="1"
                StrokeShape="RoundRectangle 12"
                Shadow="{StaticResource Elevation2}">
            <VerticalStackLayout Spacing="10">
                <!--  Mensaje de estado con icono contextual  -->
                <Border Padding="12,8"
                        BackgroundColor="{StaticResource NeutralBg}"
                        Stroke="{StaticResource DividerColor}"
                        StrokeThickness="1"
                        StrokeShape="RoundRectangle 8">
                    <Label Text="{Binding StatusMessage}"
                           FontSize="12"
                           HorizontalOptions="Center"
                           HorizontalTextAlignment="Center"
                           TextColor="{StaticResource BodyText}" />
                </Border>
                <!--  4 botones de acción con color semántico  -->
                <Grid ColumnDefinitions="*, *, *, *" ColumnSpacing="8">
                    <!--  Cargar archivo  -->
                    <Button Grid.Column="0"
                            Text="Cargar"
                            Command="{Binding CargarExcelCommand}"
                            BackgroundColor="#15803D"
                            TextColor="White"
                            Style="{StaticResource ActionBtnStyle}" />
                    <!--  Escanear código  -->
                    <Button Grid.Column="1"
                            Text="Escanear"
                            Command="{Binding EscanearQRCommand}"
                            BackgroundColor="#1A4B7A"
                            TextColor="White"
                            Style="{StaticResource ActionBtnStyle}" />
                    <!--  Exportar reporte  -->
                    <Button Grid.Column="2"
                            Text="Exportar"
                            Command="{Binding ExportarReporteCommand}"
                            BackgroundColor="#E07B1A"
                            TextColor="White"
                            Style="{StaticResource ActionBtnStyle}" />
                    <!--  Limpiar datos  -->
                    <Button Grid.Column="3"
                            Text="Limpiar"
                            Command="{Binding LimpiarAplicacionCommand}"
                            BackgroundColor="#DC2626"
                            TextColor="White"
                            Style="{StaticResource ActionBtnStyle}" />
                </Grid>
            </VerticalStackLayout>
        </Border>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  PANEL DE DETALLES DEL EMPLEADO — Ficha HR completa  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Border Grid.Row="6"
                Margin="14,8,14,10"
                Padding="0"
                IsVisible="{Binding MostrarDetalles}"
                BackgroundColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFF3E0|#E8F5E9'}"
                Stroke="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Orange|Green'}"
                StrokeThickness="1.5"
                StrokeShape="RoundRectangle 12"
                Shadow="{StaticResource Elevation3}">
            <VerticalStackLayout Spacing="0">
                <!--  Cabecera de resultado con color según estado  -->
                <Border Padding="14,10"
                        StrokeThickness="0"
                        BackgroundColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#FFF8F0|#F0FBF0'}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12,12,0,0" />
                    </Border.StrokeShape>
                    <HorizontalStackLayout Spacing="8" HorizontalOptions="Center">
                        <Label Text="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToStringConverter}, ConverterParameter='⚠️|✓'}"
                               FontSize="20"
                               TextColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Orange|Green'}" />
                        <Label Text="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToStringConverter}, ConverterParameter='REGISTRO FORZADO|CHECK-IN REGISTRADO'}"
                               FontSize="13"
                               FontAttributes="Bold"
                               VerticalOptions="Center"
                               CharacterSpacing="0.6"
                               TextColor="{Binding InvitadoSeleccionado.RegistroForzado, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Orange|Green'}" />
                    </HorizontalStackLayout>
                </Border>
                <!--  Separador  -->
                <BoxView HeightRequest="1"
                         Opacity="0.8"
                         Color="{AppThemeBinding Light=#E2E8F0,
                                                 Dark=#3D3268}" />
                <!--  Cuerpo de la ficha  -->
                <VerticalStackLayout Padding="16,14,16,16" Spacing="10">
                    <!--  Nombre del empleado  -->
                    <Label Text="{Binding InvitadoSeleccionado.Nombre}"
                           FontSize="17"
                           FontAttributes="Bold"
                           TextColor="{StaticResource HeaderText}"
                           HorizontalOptions="Center" />
                    <!--  Departamento · Supervisor  -->
                    <HorizontalStackLayout HorizontalOptions="Center" Spacing="10">
                        <Label Text="{Binding InvitadoSeleccionado.Departamento}"
                               FontSize="13"
                               TextColor="{StaticResource BodyText}" />
                        <BoxView WidthRequest="1"
                                 HeightRequest="14"
                                 VerticalOptions="Center"
                                 Color="{StaticResource DividerColor}" />
                        <Label Text="{Binding InvitadoSeleccionado.Supervisor}"
                               FontSize="13"
                               TextColor="{StaticResource BodyText}" />
                    </HorizontalStackLayout>
                    <!--  Hora de registro  -->
                    <Label Text="{Binding InvitadoSeleccionado.HoraCheckIn, StringFormat='⏱   Hora de registro: {0:HH:mm:ss}'}"
                           FontSize="12"
                           FontAttributes="Bold"
                           TextColor="{StaticResource MutedText}"
                           HorizontalOptions="Center" />
                    <!--  Chip de derecho a despensa  -->
                    <Border Padding="14,9"
                            BackgroundColor="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='#E8F5E9|#FFEBEE'}"
                            Stroke="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Green|Red'}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8">
                        <Label Text="{Binding InvitadoSeleccionado.EstadoDerecho}"
                               FontSize="13"
                               FontAttributes="Bold"
                               HorizontalOptions="Center"
                               TextColor="{Binding InvitadoSeleccionado.TieneDerechoADespensa, Converter={StaticResource BoolToColorConverter}, ConverterParameter='Green|Red'}" />
                    </Border>
                    <!--  Aviso de registro forzado  -->
                    <Border Padding="12,8"
                            BackgroundColor="{StaticResource WarnBg}"
                            Stroke="{StaticResource WarnBorder}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            IsVisible="{Binding InvitadoSeleccionado.RegistroForzado}">
                        <Label Text="⚠️  ATENCIÓN: Empleado SIN DERECHO a despensa. Registro autorizado por operador."
                               FontSize="11"
                               TextColor="{StaticResource WarnAmber}"
                               FontAttributes="Italic"
                               HorizontalOptions="Center"
                               HorizontalTextAlignment="Center" />
                    </Border>
                    <!--  Acciones  -->
                    <Grid Margin="0,4,0,0"
                          ColumnDefinitions="*, *"
                          ColumnSpacing="10">
                        <Button Grid.Column="0"
                                Text="Limpiar"
                                Command="{Binding LimpiarResultadoCommand}"
                                BackgroundColor="{StaticResource Warning}"
                                TextColor="White"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                HeightRequest="46"
                                Shadow="{StaticResource Elevation1}" />
                        <Button Grid.Column="1"
                                Text="Exportar Todo"
                                Command="{Binding ExportarReporteCommand}"
                                BackgroundColor="{StaticResource HRPrimary}"
                                TextColor="White"
                                CornerRadius="10"
                                FontAttributes="Bold"
                                HeightRequest="46"
                                Shadow="{StaticResource Elevation1}" />
                    </Grid>
                </VerticalStackLayout>
            </VerticalStackLayout>
        </Border>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  LOADING OVERLAY — Modal corporativo  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Grid Grid.RowSpan="7"
              IsVisible="{Binding IsLoading}"
              BackgroundColor="#80000000">
            <Border Padding="36,28"
                    BackgroundColor="#FFFFFF"
                    Stroke="{StaticResource CardBorder}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 16"
                    HorizontalOptions="Center"
                    VerticalOptions="Center"
                    Shadow="{StaticResource Elevation3}">
                <VerticalStackLayout Spacing="18" HorizontalOptions="Center">
                    <ActivityIndicator IsRunning="True"
                                       HeightRequest="44"
                                       WidthRequest="44"
                                       Color="{StaticResource HRPrimary}" />
                    <Label Text="Procesando..."
                           TextColor="{StaticResource HeaderText}"
                           FontSize="14"
                           FontAttributes="Bold"
                           HorizontalOptions="Center"
                           CharacterSpacing="0.4" />
                </VerticalStackLayout>
            </Border>
        </Grid>

        <!--  ══════════════════════════════════════════════════════════════  -->
        <!--  QR SCANNER OVERLAY — Vista de cámara con HUD industrial  -->
        <!--  ══════════════════════════════════════════════════════════════  -->
        <Grid Grid.RowSpan="7"
              IsVisible="{Binding IsScanning}"
              BackgroundColor="#E0000000">
            <zxing:CameraBarcodeReaderView x:Name="barcodeReader"
                                           BarcodesDetected="BarcodesDetected"
                                           IsDetecting="True" />
            <!--  Badge superior con instrucción  -->
            <Border Margin="0,52,0,0"
                    Padding="20,10"
                    BackgroundColor="#E6FFFFFF"
                    Stroke="#CCFFFFFF"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 24"
                    HorizontalOptions="Center"
                    VerticalOptions="Start"
                    Shadow="{StaticResource Elevation2}">
                <VerticalStackLayout Spacing="2" HorizontalOptions="Center">
                    <Label Text="ESCANEAR CÓDIGO DE BARRAS"
                           FontSize="9"
                           FontAttributes="Bold"
                           TextColor="{StaticResource HRPrimary}"
                           CharacterSpacing="1.5"
                           HorizontalOptions="Center" />
                    <Label Text="Apunta la cámara al código del empleado"
                           FontSize="12"
                           TextColor="{StaticResource BodyText}"
                           HorizontalOptions="Center" />
                </VerticalStackLayout>
            </Border>
            <!--  Marco de escaneo  -->
            <Grid HorizontalOptions="Center"
                  VerticalOptions="Center"
                  HeightRequest="280"
                  WidthRequest="280">
                <!--  Fondo interior semitransparente  -->
                <Border BackgroundColor="#0AFFFFFF"
                        Stroke="Transparent"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 16"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                <!--  Marco exterior  -->
                <Border Stroke="#60FFFFFF"
                        StrokeThickness="1"
                        BackgroundColor="Transparent"
                        StrokeShape="RoundRectangle 16"
                        HorizontalOptions="Fill"
                        VerticalOptions="Fill" />
                <!--  Esquinas HUD: color corporativo naranja (acción)  -->
                <!--  Superior-Izquierda  -->
                <BoxView HeightRequest="44"
                         WidthRequest="5"
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <BoxView HeightRequest="5"
                         WidthRequest="44"
                         HorizontalOptions="Start"
                         VerticalOptions="Start"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <!--  Superior-Derecha  -->
                <BoxView HeightRequest="44"
                         WidthRequest="5"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <BoxView HeightRequest="5"
                         WidthRequest="44"
                         HorizontalOptions="End"
                         VerticalOptions="Start"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <!--  Inferior-Izquierda  -->
                <BoxView HeightRequest="44"
                         WidthRequest="5"
                         HorizontalOptions="Start"
                         VerticalOptions="End"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <BoxView HeightRequest="5"
                         WidthRequest="44"
                         HorizontalOptions="Start"
                         VerticalOptions="End"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <!--  Inferior-Derecha  -->
                <BoxView HeightRequest="44"
                         WidthRequest="5"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <BoxView HeightRequest="5"
                         WidthRequest="44"
                         HorizontalOptions="End"
                         VerticalOptions="End"
                         Opacity="1.0"
                         Color="#E07B1A" />
                <!--  Línea de escaneo activo  -->
                <BoxView HeightRequest="2"
                         HorizontalOptions="Fill"
                         VerticalOptions="Center"
                         Opacity="0.5">
                    <BoxView.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="Transparent" />
                            <GradientStop Offset="0.3" Color="#E07B1A" />
                            <GradientStop Offset="0.7" Color="#F0922A" />
                            <GradientStop Offset="1" Color="Transparent" />
                        </LinearGradientBrush>
                    </BoxView.Background>
                </BoxView>
            </Grid>
            <!--  Botón cancelar  -->
            <Border Margin="0,0,0,52"
                    Padding="0"
                    BackgroundColor="#E6FFFFFF"
                    StrokeThickness="1.5"
                    Stroke="#CCFFFFFF"
                    StrokeShape="RoundRectangle 24"
                    HorizontalOptions="Center"
                    VerticalOptions="End"
                    Shadow="{StaticResource Elevation2}">
                <Button Text="✕   Cancelar"
                        Clicked="OnCancelScanClicked"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource DangerRed}"
                        CornerRadius="22"
                        WidthRequest="155"
                        HeightRequest="48"
                        FontAttributes="Bold"
                        FontSize="14"
                        CharacterSpacing="0.4" />
            </Border>
        </Grid>

    </Grid>
</ContentPage>
